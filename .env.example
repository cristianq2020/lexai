# =============================================================================
# LexAI v2 — Environment Variables
# Copy this file to .env and fill in values for local development.
# NEVER commit .env with real secrets to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------

# Node environment: development | test | production
NODE_ENV=development

# Public URL of the Next.js web app (used for CORS, redirects, emails)
WEB_URL=http://localhost:3000

# Base URL of the Fastify API (used by web app and webhooks)
API_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Database (PostgreSQL 16)
# -----------------------------------------------------------------------------

# Prisma / Drizzle connection string
# Local dev (docker-compose): postgres://lexai:lexai_dev_password@localhost:5432/lexai
DATABASE_URL=postgres://lexai:lexai_dev_password@localhost:5432/lexai

# -----------------------------------------------------------------------------
# Cache & Queues (Redis 7)
# -----------------------------------------------------------------------------

# Redis connection URL for sessions, rate limiting, BullMQ job queues
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# Authentication (NextAuth.js)
# -----------------------------------------------------------------------------

# Random secret for signing JWTs and encrypting cookies (min 32 chars)
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-here

# JWT signing for API auth (falls back to NEXTAUTH_SECRET if unset)
JWT_SECRET=your-jwt-secret-here-min-32-chars

# Canonical URL of the web app for NextAuth callbacks
NEXTAUTH_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# AI (xAI / Grok)
# -----------------------------------------------------------------------------

# xAI API key for legal reasoning, document analysis, and chat
XAI_API_KEY=xai-your-api-key-here

# xAI model routing (optional overrides)
XAI_HEAVY_MODEL=grok-4.3
XAI_VOLUME_MODEL=grok-4.3

# Set to true to never call Grok (use intelligent local engine — $0 cost)
# XAI_FORCE_MOCK=true

# -----------------------------------------------------------------------------
# Payments (Stripe)
# -----------------------------------------------------------------------------

# Stripe secret key (sk_test_* for dev, sk_live_* for production)
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key

# Webhook signing secret from Stripe Dashboard → Developers → Webhooks
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# Price IDs for subscription tiers (create in Stripe Dashboard → Products)
STRIPE_PRICE_STARTER_MONTHLY=price_starter_monthly_id
STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual_id
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_PRO_ANNUAL=price_pro_annual_id
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_enterprise_monthly_id
STRIPE_PRICE_ENTERPRISE_ANNUAL=price_enterprise_annual_id

# -----------------------------------------------------------------------------
# Real-time (LiveKit — video consultations, depositions)
# -----------------------------------------------------------------------------

# LiveKit project API key
LIVEKIT_API_KEY=your-livekit-api-key

# LiveKit project API secret
LIVEKIT_API_SECRET=your-livekit-api-secret

# LiveKit server WebSocket URL (wss://your-project.livekit.cloud)
LIVEKIT_URL=wss://your-project.livekit.cloud

# -----------------------------------------------------------------------------
# Telephony (Twilio — SMS notifications, call routing)
# -----------------------------------------------------------------------------

# Twilio account SID from console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Twilio auth token
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# Outbound / verified Twilio phone number in E.164 format (+1XXXXXXXXXX)
TWILIO_PHONE_NUMBER=+10000000000

# -----------------------------------------------------------------------------
# Object Storage (Cloudflare R2 — S3-compatible)
# Local dev: use MinIO from docker-compose (see R2_ENDPOINT below)
# -----------------------------------------------------------------------------

# Cloudflare account ID (found in R2 dashboard URL)
R2_ACCOUNT_ID=your-cloudflare-account-id

# R2 API token access key ID
R2_ACCESS_KEY_ID=your-r2-access-key-id

# R2 API token secret access key
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# Bucket name for case documents, uploads, generated PDFs
R2_BUCKET_NAME=lexai-uploads

# S3-compatible endpoint
# Local MinIO: http://localhost:9000
# Production R2: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT=http://localhost:9000

# -----------------------------------------------------------------------------
# Email (Resend)
# -----------------------------------------------------------------------------

# Resend API key for transactional emails (invites, billing, alerts)
RESEND_API_KEY=re_your-resend-api-key

# -----------------------------------------------------------------------------
# Error Monitoring (Sentry)
# -----------------------------------------------------------------------------

# Sentry DSN for API and web error tracking (leave empty to disable locally)
SENTRY_DSN=https://your-key@o000000.ingest.sentry.io/0000000

# -----------------------------------------------------------------------------
# Supabase (optional — auth/storage alternative or realtime features)
# -----------------------------------------------------------------------------

# Supabase project URL (optional; leave empty if not using Supabase)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (optional)
SUPABASE_ANON_KEY=your-supabase-anon-key

# -----------------------------------------------------------------------------
# Encryption (AES-256-GCM for PII / privileged document fields at rest)
# -----------------------------------------------------------------------------

# 32-byte master key, base64-encoded
# Generate: openssl rand -base64 32
# NEVER rotate without a migration plan — data encrypted with old key becomes unreadable
ENCRYPTION_MASTER_KEY=your-base64-encoded-32-byte-key-here